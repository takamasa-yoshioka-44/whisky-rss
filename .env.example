# =============================================================
# whisky-rss .env example
# 使い方: cp .env.example .env して値を埋める
# =============================================================

# --- Aggregator ---
# 内部の RSSHub サービスをそのまま参照する
RSSHUB_BASE_URL=http://rsshub:1200

# 通知のWebhook (使うものだけ埋める。空ならその通知先はスキップ)
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# 取得間隔(分)。デフォルト30分
FETCH_INTERVAL_MIN=30

# 1記事あたりの通知本文の最大文字数
NOTIFY_BODY_MAX_CHARS=400

# DeepL 翻訳 (空なら翻訳せず原文のまま通知)
# 英語記事のタイトル・本文を日本語訳して Discord に併記する
DEEPL_API_KEY=
DEEPL_API_URL=https://api-free.deepl.com/v2/translate
TRANSLATE_TARGET_LANG=JA

# --- Miniflux (任意のWeb UI) ---
MINIFLUX_DB_PASSWORD=change-me-strong-password
MINIFLUX_ADMIN_USER=admin
MINIFLUX_ADMIN_PASSWORD=change-me-too

# --- RSSHub ---
# 必要に応じて RSSHub の各サービス用 access key などを設定
# https://docs.rsshub.app/deploy/config
# RSSHUB_ACCESS_KEY=
